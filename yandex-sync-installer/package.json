{
  "name": "yandex-sync-installer",
  "version": "1.2.0",
  "description": "Installer for Better Yandex Music sync",
  "main": "main.js",
  "scripts": {
    "start": "chcp 65001 >NUL & electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "IvanForze",
  "license": "ISC",
  "dependencies": {
    "@electron/asar": "^3.2.14",
    "@electron/fuses": "^1.8.0"
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.better.yandexmusic.installer",
    "productName": "BetterYandexMusic Installer",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "../yandex-sync-electron",
        "to": "assets",
        "filter": [
          "socket.io.js",
          "desktop-sync.js"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/Icon-iOS-Default-1024x1024@1x.png"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/Icon.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/Icon.png"
    }
  }
}
